{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EASYAnalyse Desktop",
  "version": "0.1.0",
  "identifier": "com.easyanalyse.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EASYAnalyse Desktop",
        "width": 1640,
        "height": 1040,
        "minWidth": 1280,
        "minHeight": 820,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
