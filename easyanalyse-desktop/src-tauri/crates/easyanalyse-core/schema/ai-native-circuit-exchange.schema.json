{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://easyanalyse.local/schema/ai-native-semantic-circuit.schema.json",
  "title": "EASYAnalyse Semantic Circuit Exchange",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "document",
    "devices",
    "view"
  ],
  "properties": {
    "schemaVersion": {
      "const": "4.0.0"
    },
    "document": {
      "$ref": "#/$defs/documentMeta"
    },
    "devices": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/deviceDefinition"
      }
    },
    "view": {
      "$ref": "#/$defs/viewDefinition"
    },
    "extensions": {
      "$ref": "#/$defs/extensions"
    }
  },
  "$defs": {
    "extensions": {
      "type": "object",
      "additionalProperties": true
    },
    "documentSource": {
      "type": "string",
      "enum": [
        "human",
        "ai",
        "mixed",
        "imported"
      ]
    },
    "documentMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/documentSource"
        },
        "language": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "terminalDirection": {
      "type": "string",
      "enum": [
        "input",
        "output",
        "bidirectional",
        "passive",
        "power-in",
        "power-out",
        "ground",
        "shield",
        "unspecified"
      ]
    },
    "terminalSide": {
      "type": "string",
      "enum": [
        "left",
        "right",
        "top",
        "bottom",
        "auto"
      ]
    },
    "terminalPin": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "number": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "bank": {
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "terminalDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "direction"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "direction": {
          "$ref": "#/$defs/terminalDirection"
        },
        "logicalDirection": {
          "$ref": "#/$defs/terminalDirection"
        },
        "role": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "pin": {
          "$ref": "#/$defs/terminalPin"
        },
        "required": {
          "type": "boolean"
        },
        "side": {
          "$ref": "#/$defs/terminalSide"
        },
        "order": {
          "type": "integer"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "deviceProperties": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        },
        "voltage": {
          "type": "string",
          "minLength": 1
        },
        "outputVoltage": {
          "type": "string",
          "minLength": 1
        },
        "nominalVoltage": {
          "type": "string",
          "minLength": 1
        },
        "frequency": {
          "type": "string",
          "minLength": 1
        },
        "partNumber": {
          "type": "string",
          "minLength": 1
        },
        "package": {
          "type": "string",
          "minLength": 1
        },
        "topology": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "deviceDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "kind",
        "terminals"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "reference": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "properties": {
          "$ref": "#/$defs/deviceProperties"
        },
        "terminals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/terminalDefinition"
          }
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "resistor"
              }
            }
          },
          "then": {
            "required": [
              "properties"
            ],
            "properties": {
              "properties": {
                "required": [
                  "value"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "capacitor"
              }
            }
          },
          "then": {
            "required": [
              "properties"
            ],
            "properties": {
              "properties": {
                "required": [
                  "value"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "inductor"
              }
            }
          },
          "then": {
            "required": [
              "properties"
            ],
            "properties": {
              "properties": {
                "required": [
                  "value"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "crystal"
              }
            }
          },
          "then": {
            "required": [
              "properties"
            ],
            "properties": {
              "properties": {
                "required": [
                  "frequency"
                ]
              }
            }
          }
        }
      ]
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      }
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height"
      ],
      "properties": {
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "gridDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "size"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "size": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "majorEvery": {
          "type": "integer",
          "minimum": 2
        }
      }
    },
    "deviceShape": {
      "type": "string",
      "enum": [
        "rectangle",
        "circle",
        "triangle"
      ]
    },
    "deviceViewDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "position": {
          "$ref": "#/$defs/point"
        },
        "size": {
          "$ref": "#/$defs/size"
        },
        "rotationDeg": {
          "type": "number"
        },
        "shape": {
          "$ref": "#/$defs/deviceShape"
        },
        "locked": {
          "type": "boolean"
        },
        "collapsed": {
          "type": "boolean"
        },
        "groupId": {
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "networkLineOrientation": {
      "type": "string",
      "enum": [
        "horizontal",
        "vertical"
      ]
    },
    "networkLineViewDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "position"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "position": {
          "$ref": "#/$defs/point"
        },
        "length": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "orientation": {
          "$ref": "#/$defs/networkLineOrientation"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "focusDirection": {
      "type": "string",
      "enum": [
        "left-to-right",
        "top-to-bottom",
        "auto"
      ]
    },
    "focusViewDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultDeviceId": {
          "type": "string"
        },
        "preferredDirection": {
          "$ref": "#/$defs/focusDirection"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "canvasViewDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "units"
      ],
      "properties": {
        "units": {
          "const": "px"
        },
        "grid": {
          "$ref": "#/$defs/gridDefinition"
        },
        "background": {
          "const": "grid"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "viewDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canvas"
      ],
      "properties": {
        "canvas": {
          "$ref": "#/$defs/canvasViewDefinition"
        },
        "devices": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/deviceViewDefinition"
          }
        },
        "networkLines": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/networkLineViewDefinition"
          }
        },
        "focus": {
          "$ref": "#/$defs/focusViewDefinition"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    }
  }
}
